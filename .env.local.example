# stock-query 本地测试配置
# 复制为 .env.local 并填入实际值

# --- E2E 测试必需（仅 agent 测试层用到）---
ANTHROPIC_API_KEY=

# --- 测试标的代码（可覆盖默认值）---
TEST_STOCK_SH=600519
TEST_STOCK_SZ=000001
TEST_ETF_SH=510300
TEST_ETF_SZ=159915
TEST_FUND=110011
TEST_FUND_QDII=005827
TEST_CODE_COLLISION=563230
TEST_HK_STOCK=00700
TEST_US_STOCK=AAPL
TEST_US_INDEX=.DJI

# --- 层级开关 ---
RUN_UNIT=true
RUN_INTEGRATION=true
RUN_E2E=false

# --- 交易时间 ---
# auto | force_trading | force_closed
MARKET_HOURS=auto

# --- 超时（秒）---
INTEGRATION_TIMEOUT=10
E2E_TIMEOUT=60
